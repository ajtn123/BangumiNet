<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:bn="https://github.com/ajtn123/BangumiNet"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="BangumiNet.Views.MainWindow"
        x:DataType="bn:MainWindowViewModel"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        xmlns:ice="using:FluentIcons.Avalonia.Fluent.Markup"
        Title="{Binding Title}">

    <Design.DataContext>
        <bn:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <ui:FANavigationView Grid.Column="1" Name="NavView"
                           PaneDisplayMode="Left"
                           IsPaneOpen="False">
            <ui:FANavigationView.AutoCompleteBox>
                <AutoCompleteBox Name="Navigator"/>
            </ui:FANavigationView.AutoCompleteBox>

            <ui:FANavigationView.MenuItems>
                <ui:FANavigationViewItem Content="主页" IconSource="{ice:FluentIconSource News}"/>

                <ui:FANavigationViewItem Content="每日放送" IconSource="{ice:FluentIconSource Live}"/>

                <ui:FANavigationViewItem Content="小组" IconSource="{ice:FluentIconSource PeopleTeam}"/>

                <ui:FANavigationViewItem Content="搜索" IconSource="{ice:FluentIconSource Search}"/>

                <ui:FANavigationViewItem Content="分类浏览" IconSource="{ice:FluentIconSource ListBar}"/>

                <ui:FANavigationViewItem Content="番组索引" IconSource="{ice:FluentIconSource DatabaseLink}"/>
            </ui:FANavigationView.MenuItems>

            <ui:FANavigationView.FooterMenuItems>
                <ui:FANavigationViewItem Content="我" IconSource="{ice:FluentIconSource Person}"/>
            </ui:FANavigationView.FooterMenuItems>
        </ui:FANavigationView>

        <ui:FAInfoBar Name="Info" IsOpen="False" IsClosable="True"
                    VerticalAlignment="Bottom" Margin="20"/>
    </Panel>
</Window>
