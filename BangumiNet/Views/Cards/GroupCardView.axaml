<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:bn="https://github.com/ajtn123/BangumiNet"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:ice="using:FluentIcons.Avalonia.Fluent.Markup"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="bn:GroupViewModel"
             x:Class="BangumiNet.Views.GroupCardView">
    <Grid ColumnDefinitions="50,*" ColumnSpacing="5" Classes="PointoverTextHost">
        <MainImage Url="{Binding Images?.Large}" VerticalAlignment="Top">
            <bn:GroupFlyoutView />
        </MainImage>

        <StackPanel Grid.Column="1">
            <HyperlinkButton Content="{Binding Name}" Classes="Title" Command="{Binding OpenInNewWindowCommand}" />
            <WrapPanel Classes="InfoBar">
                <InfoItem Tip="小组名" Text="{Binding Groupname}" Classes="Sec" />
                <InfoItem Tip="成员数" Text="{Binding MemberCount}" Icon="People" />
                <TextBlock>
                    <ic:FluentIcon ToolTip.Tip="NSFW" Icon="CalendarDate" IsVisible="{Binding IsNsfw}" />
                    <ic:FluentIcon ToolTip.Tip="本小组不可访问" Icon="LockClosed" IsVisible="{Binding !Accessible}" />
                </TextBlock>
            </WrapPanel>
        </StackPanel>

        <Grid.ContextFlyout>
            <Flyout>
                <bn:GroupFlyoutView />
            </Flyout>
        </Grid.ContextFlyout>
    </Grid>
</UserControl>
