<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:bn="https://github.com/ajtn123/BangumiNet"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:ice="using:FluentIcons.Avalonia.Fluent.Markup"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="bn:TopicViewModel"
             x:Class="BangumiNet.Views.TopicFlyoutView">
    <StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="5">
            <ic:FluentIcon Icon="{Binding Icon}" FontSize="24" />
            <Button Classes="Icon" Command="{Binding OpenInNewWindowCommand}" Content="{ice:FluentIcon Icon=Open}" ToolTip.Tip="在新窗口显示" />
            <Button Classes="Icon" Command="{Binding SearchWebCommand}" Content="{ice:FluentIcon Icon=Search}" ToolTip.Tip="搜索 Web" />
            <Button Classes="Icon" Command="{Binding OpenInBrowserCommand}" Content="{ice:FluentIcon Icon=Globe}" ToolTip.Tip="在 bangumi.tv 显示" />
        </StackPanel>
        <Separator />
        <TextBlock Text="{Binding Name}"
                   IsVisible="{Binding $self.Text,Converter={StaticResource NEWCvt}}"
                   Classes="Title" />
        <WrapPanel Classes="InfoBar">
            <Border Background="Red" CornerRadius="5" Padding="3,0" IsVisible="{Binding State, Converter={StaticResource ZeroCvt}}">
                <InfoItem Tip="评论状态" CommonText="{Binding State, Converter={StaticResource EnumCvt}}" Icon="Warning" Foreground="White" />
            </Border>
            <Border Background="Red" CornerRadius="5" Padding="3,0" IsVisible="{Binding !IsDisplayed}">
                <InfoItem Tip="话题状态" CommonText="{Binding Display, Converter={StaticResource EnumCvt}}" Icon="Warning" Foreground="White" />
            </Border>
            <InfoItem Tip="评论数" Text="{Binding ReplyCount}" Icon="Comment" />
            <InfoItem Tip="更新时间" CommonText="{Binding UpdateTime}" Icon="DocumentArrowUp" />
            <InfoItem Tip="创建时间" CommonText="{Binding CreationTime}" Icon="DocumentAdd" />
            <InfoItem Tip="ID" Text="{Binding Id}" Icon="SlideText" />
        </WrapPanel>
        <Separator />
        <bn:CardView Content="{Binding User}" />
        <bn:CardView Content="{Binding Parent}" Margin="0,5,0,0" />
    </StackPanel>
</UserControl>
